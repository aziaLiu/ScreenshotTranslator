<Window x:Class="ScreenshotTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="截图翻译"
        Icon="Assets/AppIcon.ico"
        Height="680"
        Width="980"
        MinHeight="560"
        MinWidth="780"
        Background="#F4F1EA">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#16302B"/>
            <Setter Property="Foreground" Value="#FFF9ED"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderBrush" Value="#D7C7A6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFDF6"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="#D7C7A6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFDF6"/>
        </Style>
    </Window.Resources>
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="20" Background="#16302B" Padding="24" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="截图翻译" Foreground="#FFF9ED" FontSize="34" FontWeight="Black"/>
                    <TextBlock Text="按下自定义热键，框选屏幕区域，自动识别并翻译为中文。"
                               Foreground="#D8E2D5"
                               FontSize="15"
                               Margin="0,8,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#E6A23C" CornerRadius="14" Padding="16,10" VerticalAlignment="Center">
                    <TextBlock x:Name="HotkeyBadge" Text="Ctrl+Shift+T" FontWeight="Bold" Foreground="#1A1712"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#FFFDF6" BorderBrush="#D7C7A6" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="热键" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <TextBox x:Name="HotkeyTextBox"
                         Grid.Column="1"
                         IsReadOnly="True"
                         PreviewKeyDown="HotkeyTextBox_OnPreviewKeyDown"
                         GotKeyboardFocus="HotkeyTextBox_OnGotKeyboardFocus"/>
                <TextBlock Grid.Column="2" Text="识别语言" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,12,0"/>
                <ComboBox x:Name="SourceLanguageComboBox"
                          Grid.Column="3"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="SourceLanguageComboBox_OnSelectionChanged"/>
                <Button x:Name="CaptureButton"
                        Grid.Column="4"
                        Content="立即截图"
                        Click="CaptureButton_OnClick"
                        Margin="16,0,10,0"/>
                <Button x:Name="SaveHotkeyButton"
                        Grid.Column="5"
                        Content="保存热键"
                        HorizontalAlignment="Left"
                        Background="#8B3A2F"
                        Click="SaveHotkeyButton_OnClick"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#FFFDF6" BorderBrush="#D7C7A6" BorderThickness="1" CornerRadius="16" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="识别文本" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button x:Name="TranslateEditedTextButton"
                                Grid.Column="1"
                                Content="翻译当前文本"
                                Padding="14,8"
                                Margin="0"
                                Click="TranslateEditedTextButton_OnClick"/>
                    </Grid>
                    <TextBox x:Name="OcrTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="15"/>
                </Grid>
            </Border>
            <Border Grid.Column="2" Background="#FFFDF6" BorderBrush="#D7C7A6" BorderThickness="1" CornerRadius="16" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="中文翻译" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBox x:Name="TranslationTextBox"
                             Grid.Row="1"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="15"/>
                </Grid>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Text="就绪"
                   Foreground="#5B574E"
                   Margin="2,14,0,0"/>
    </Grid>
</Window>
